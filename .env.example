# Unbinge extension build-time secrets
# Copy this file to .env and fill in real values.
# .env is gitignored — NEVER commit it.
#
# These values are injected into the built extension via Vite's import.meta.env.
# They still ship in the packaged extension (client-side), so treat them as
# public-ish. For true secrecy, proxy sensitive calls through the PHP backend.

# Must match API_KEY in website/api/includes/config.php
VITE_EXT_API_KEY=YOUR_EXT_API_KEY_HERE

# YouTube Data API v3 key (Google Cloud Console)
# TODO: proxy through PHP backend so this isn't shipped to clients
VITE_YOUTUBE_DATA_API_KEY=YOUR_YOUTUBE_DATA_API_KEY_HERE
