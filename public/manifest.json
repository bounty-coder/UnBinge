{
  "manifest_version": 3,
  "name": "Unbinge",
  "description": "Unbinge turns YouTube into a distraction-free, whitelist-based learning space for kids.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Safe YouTube",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtube.com/*",
    "https://www.googleapis.com/*",
    "https://unbinge.watch/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["assets/content.js"],
      "css": ["content/unhook.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.js"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ]
    }
  ]
}
