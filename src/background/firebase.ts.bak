import type {
  AgeCategory,
  ChannelRequestPayload,
  WhitelistChannel
  // WhitelistVideo // disabled in v1 — see fetchApprovedVideos note below
} from "../shared/types";

type FirestoreValue = {
  stringValue?: string;
  integerValue?: string;
  doubleValue?: number;
  booleanValue?: boolean;
  timestampValue?: string;
  arrayValue?: {
    values?: FirestoreValue[];
  };
};

type FirestoreDocument = {
  name: string;
  fields?: Record<string, FirestoreValue>;
};

type RunQueryResponse = {
  document?: FirestoreDocument;
};

export async function fetchApprovedChannels(
  ageCategory: AgeCategory,
  languages: string[]
): Promise<WhitelistChannel[]> {
  ensureFirestoreConfigured();

  const rows = await runCollectionQuery(FIRESTORE_COLLECTIONS.whitelistChannels, [
    fieldEquals("status", "approved"),
    fieldArrayContains("ageCategories", ageCategory)
  ]);

  return rows
    .map(documentToChannel)
    .filter(channel => channel.status === "approved")
    .filter(channel => matchesLanguages(channel.languages, languages));
}

