export async function submitChannelRequest(payload: ChannelRequestPayload): Promise<void> {
  ensureFirestoreConfigured();

  const body = {
    fields: {
      submittedInput: stringField(payload.submittedInput),
      normalizedUrl: stringField(payload.normalizedUrl ?? ""),
      channelId: stringField(payload.channelId ?? ""),
      handle: stringField(payload.handle ?? ""),
      title: stringField(payload.title ?? ""),
      requestedAgeCategory: stringField(payload.requestedAgeCategory),
      requestedLanguages: arrayField(payload.requestedLanguages),
      requestReason: stringField(payload.requestReason ?? ""),
      source: stringField(payload.source),
      localApproval: booleanField(payload.localApproval),
      status: stringField("pending_review"),
      extensionVersion: stringField(chrome.runtime.getManifest().version),
      createdAt: timestampField(new Date())
    }
  };

  const response = await fetch(
    firestoreUrl(`documents/${FIRESTORE_COLLECTIONS.requestedChannels}`),
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(body)
    }
  );

  if (!response.ok) {
    throw new Error(`Failed to submit channel request: ${response.status}`);
  }
}

export function getFirestoreConfigurationError(): string | null {
  return isFirestoreConfigured()
    ? null
    : "Configure FIREBASE_PROJECT_ID and FIREBASE_WEB_API_KEY in src/shared/constants.ts.";
}

async function runCollectionQuery(
  collectionId: string,
  filters: Record<string, unknown>[]
): Promise<FirestoreDocument[]> {
  const response = await fetch(firestoreUrl("documents:runQuery"), {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      structuredQuery: {
        from: [{ collectionId }],
        where: {
          compositeFilter: {
            op: "AND",
            filters
          }
        }
      }
    })
  });

  if (!response.ok) {
    throw new Error(`Firestore query failed for ${collectionId}: ${response.status}`);
  }

  const rows = (await response.json()) as RunQueryResponse[];
  return rows.map(row => row.document).filter((document): document is FirestoreDocument => Boolean(document));
}

function documentToChannel(document: FirestoreDocument): WhitelistChannel {
  const fields = document.fields ?? {};

  return {
    channelId: stringValue(fields.channelId) || document.name.split("/").pop() || "",
    handle: stringValue(fields.handle) || undefined,
    title: stringValue(fields.title) || "Approved channel",
    languages: arrayValue(fields.languages),
    ageCategories: arrayValue(fields.ageCategories) as AgeCategory[],
    status: "approved",
    badge: "global_verified",
    updatedAt: timestampToMillis(fields.updatedAt)
  };
}

