function fieldEquals(fieldPath: string, value: string): Record<string, unknown> {
  return {
    fieldFilter: {
      field: { fieldPath },
      op: "EQUAL",
      value: stringField(value)
    }
  };
}

function fieldArrayContains(fieldPath: string, value: string): Record<string, unknown> {
  return {
    fieldFilter: {
      field: { fieldPath },
      op: "ARRAY_CONTAINS",
      value: stringField(value)
    }
  };
}

function firestoreUrl(path: string): string {
  const encodedKey = encodeURIComponent(FIREBASE_WEB_API_KEY);
  const databaseId = encodeURIComponent(FIREBASE_DATABASE_ID);
  return `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT_ID}/databases/${databaseId}/${path}?key=${encodedKey}`;
}

function ensureFirestoreConfigured(): void {
  const error = getFirestoreConfigurationError();

  if (error) {
    throw new Error(error);
  }
}

function matchesLanguages(channelLanguages: string[], selectedLanguages: string[]): boolean {
  if (selectedLanguages.length === 0 || channelLanguages.length === 0) {
    return true;
  }

  return channelLanguages.some(language => selectedLanguages.includes(language));
}

function stringField(value: string): FirestoreValue {
  return { stringValue: value };
}

function booleanField(value: boolean): FirestoreValue {
  return { booleanValue: value };
}

function timestampField(value: Date): FirestoreValue {
  return { timestampValue: value.toISOString() };
}

function arrayField(values: string[]): FirestoreValue {
  return {
    arrayValue: {
      values: values.map(stringField)
    }
  };
}

function stringValue(value: FirestoreValue | undefined): string {
  return value?.stringValue ?? "";
}

function arrayValue(value: FirestoreValue | undefined): string[] {
  return value?.arrayValue?.values?.flatMap(item => (item.stringValue ? [item.stringValue] : [])) ?? [];
}

function timestampToMillis(value: FirestoreValue | undefined): number | undefined {
  if (!value?.timestampValue) {
    return undefined;
  }

  const parsed = Date.parse(value.timestampValue);
  return Number.isNaN(parsed) ? undefined : parsed;
}
